# =========================
# Docker related
# =========================
# Bỏ thư mục build của Docker (nếu có)
**/docker-build/
**/docker-cache/
**/.docker/

# Bỏ log trong container (nếu mount ra host)
*.log
logs/
tmp/
temp/

# Bỏ file môi trường chứa thông tin nhạy cảm
.env
.env.local
.env.*.local

# Docker compose override file (thường chỉ dùng local)
docker-compose.override.yml
docker-compose.yml

# =========================
# Node / Python / Java / etc.
# (tùy theo project của bạn)
# =========================
# Node
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Python
__pycache__/
*.py[cod]
*.egg
*.egg-info/
dist/
build/

# Java (nếu có)
target/
*.class
*.jar
*.war
*.ear

# =========================
# IDE / Editor
# =========================
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
